# Copy to .env (backend). Development keeps safe, zero-setup defaults.

# Explicit runtime mode: development, test, or production.
# Production requires a non-empty admin token and explicit non-wildcard web origins.
SCOUTBOY_ENVIRONMENT=development

# Database. Default is a local SQLite file. For Postgres:
#   DATABASE_URL=postgresql+psycopg://scoutboy:scoutboy@localhost:5432/scoutboy
DATABASE_URL=sqlite:///./db/scoutboy.db

# Minimum minutes threshold for a player-season to be eligible for scoring.
SCOUTBOY_MIN_MINUTES=450

# Shared secret gating /api/admin/* endpoints. Empty is allowed only outside production.
SCOUTBOY_ADMIN_TOKEN=

# Comma-separated browser origins allowed by CORS (no `*` anywhere in production).
SCOUTBOY_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Browser-visible API URL compiled into the Next.js production bundle.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Mock commercial fixture only: required solely with --credential-required-mode.
# This is not a real provider credential and the adapter never makes network requests.
SCOUTBOY_MOCK_COMMERCIAL_TOKEN=dummy-local-fixture-token
