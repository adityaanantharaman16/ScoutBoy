# Copy to .env (backend) — all have safe defaults, nothing is required for SQLite.

# Database. Default is a local SQLite file. For Postgres:
#   DATABASE_URL=postgresql+psycopg://scoutboy:scoutboy@localhost:5432/scoutboy
DATABASE_URL=sqlite:///./db/scoutboy.db

# Minimum minutes threshold for a player-season to be eligible for scoring.
SCOUTBOY_MIN_MINUTES=450

# Simple shared secret gating POST /api/admin/* (local admin only). Empty = allow all locally.
SCOUTBOY_ADMIN_TOKEN=

# CORS origin for the web app.
SCOUTBOY_WEB_ORIGIN=http://localhost:3000
